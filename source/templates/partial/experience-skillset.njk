<div class="skillset-inner">
  <div class="section-eyebrow fade-up">What I Do</div>
  <div class="section-title fade-up">Skills & Expertise</div>

  <div class="skillset-content stagger">
    {% for role in roles -%}
      <div class="skill-card fade-up">
        <div
          class="role-icon icon-bounce"
          style="background-image: url('/assets/images/{{ role.icon }}')"
          aria-hidden="true"
        ></div>

        <strong class="role-label">{{ role.name }}</strong>

        <p class="role-description">{{ role.description }}</p>

        {% if role.languages %}
          <span class="skill-label">Languages</span>
          <div class="skill-tags">{{ role.languages | join(" / ") }}</div>
        {% endif %}

        {% if role.tools %}
          <span class="skill-label">Tools & Frameworks</span>
          <ul class="skill-list">
            {% for tool in role.tools -%}
              <li>{{ tool }}</li>
            {%- endfor %}
          </ul>
        {% endif %}

        {% if role.knowledge %}
          <span class="skill-label">Core Principles</span>
          <ul class="skill-list">
            {% for item in role.knowledge -%}
              <li>{{ item }}</li>
            {%- endfor %}
          </ul>
        {% endif %}
      </div>
    {%- endfor %}
  </div>
</div>
