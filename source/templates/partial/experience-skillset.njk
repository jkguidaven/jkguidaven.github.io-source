<div class="skills-section">
  <div class="section-eyebrow">What I Do</div>
  <div class="section-title">Skills & Expertise</div>

  <div class="skills-grid">
    {% for role in roles -%}
      <div class="skill-card">
        <div
          class="skill-icon"
          style="background-image: url('/assets/images/{{ role.icon }}')"
          aria-hidden="true"
        ></div>

        <div class="skill-title">{{ role.name }}</div>

        <p class="skill-description">{{ role.description }}</p>

        {% if role.languages %}
          <span class="skill-label">Languages</span>
          <div class="skill-tags">{{ role.languages | join(" / ") }}</div>
        {% endif %}

        {% if role.tools %}
          <span class="skill-label">Tools & Frameworks</span>
          <ul class="skill-list">
            {% for tool in role.tools -%}
              <li>{{ tool }}</li>
            {%- endfor %}
          </ul>
        {% endif %}

        {% if role.knowledge %}
          <span class="skill-label">Core Principles</span>
          <ul class="skill-list">
            {% for item in role.knowledge -%}
              <li>{{ item }}</li>
            {%- endfor %}
          </ul>
        {% endif %}
      </div>
    {%- endfor %}
  </div>
</div>
