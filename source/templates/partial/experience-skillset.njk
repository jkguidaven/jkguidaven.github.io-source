<div class="skillset-inner">
  <div class="section-eyebrow fade-up">Toolkit</div>
  <h2 class="section-title fade-up">What I Work With</h2>
  <p class="section-subtitle fade-up">
    From UI frameworks to cloud services — the stack behind the work
  </p>

  <div class="terminal-window blur-in">
    <div class="terminal-header">
      <div class="terminal-dots">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <span class="terminal-title">skills.sh</span>
    </div>

    <div class="terminal-body">
      {% for role in roles -%}
        <div class="terminal-block" data-index="{{ loop.index0 }}">
          <div class="terminal-prompt">
            <span class="prompt-symbol">$</span>
            <span class="prompt-cmd">cat</span>
            <span class="prompt-arg">{{ role.name | lower | replace(" ", "-") }}.md</span>
          </div>

          <div class="terminal-output">
            <div class="output-header">
              <span class="output-hash">#</span>&nbsp;{{ role.name }}
              {% if loop.first %}&nbsp;<span class="output-badge">primary</span>{% endif %}
            </div>

            <p class="output-desc">&gt;&nbsp;{{ role.description }}</p>

            {% if role.languages %}
              <div class="output-section">
                <span class="output-key">languages:</span>
                <span class="output-values">
                  {% for lang in role.languages -%}
                    <span class="output-tag">{{ lang }}</span>
                  {%- endfor %}
                </span>
              </div>
            {% endif %}

            {% if role.tools %}
              <div class="output-section">
                <span class="output-key">tools:</span>
                <span class="output-values">
                  {% for tool in role.tools -%}
                    <span class="output-tag">{{ tool }}</span>
                  {%- endfor %}
                </span>
              </div>
            {% endif %}

            {% if role.knowledge %}
              <div class="output-section">
                <span class="output-key">principles:</span>
                <span class="output-values">
                  {% for item in role.knowledge -%}
                    <span class="output-tag">{{ item }}</span>
                  {%- endfor %}
                </span>
              </div>
            {% endif %}
          </div>
        </div>

        {% if not loop.last %}
          <div class="terminal-divider"></div>
        {% endif %}
      {%- endfor %}

      <div class="terminal-prompt terminal-cursor">
        <span class="prompt-symbol">$</span>
        <span class="cursor-blink">_</span>
      </div>
    </div>
  </div>
</div>
