<div class="experience-section">
  <div class="section-eyebrow">Experience</div>
  <div class="section-title">Companies I've Worked With</div>

  <div class="company-grid">
    {% for company in companies -%}
      <a class="company-card" href="{{ company.url }}" rel="noreferrer" target="_blank">
        <div
          class="company-logo lazyload"
          data-bg="/assets/images/companies/{{ company.brand.image }}"
          style="background-color: {{ company.brand.color }}; background-size: {{ company.brand.size }};"
        ></div>
        <div class="company-name">{{ company.name }}</div>
        <div class="company-role">{{ company.role }}</div>
      </a>
    {%- endfor %}
  </div>
</div>
