<div class="about-statement-strip fade-up">
  <span class="statement-number">7</span> companies.
  <span class="statement-number">15+</span> years.
  <span class="statement-highlight">Here's the journey.</span>
</div>

<section class="timeline-section" id="experience">
  <div class="section-eyebrow fade-up">Career</div>
  <h2 class="section-title fade-up">Work Experience & Education</h2>

  <div class="year-timeline">
    {% for record in timeline -%}
      <div class="year-row blur-in" style="transition-delay: {{ loop.index0 * 0.1 }}s">
        <div class="year-anchor">
          <span class="year-number">{{ record.year }}</span>
          {% if loop.first %}
            <span class="year-now">Now</span>
          {% endif %}
        </div>

        <div class="year-line"></div>

        <div class="year-detail">
          <h3 class="year-company">{{ record.title }}</h3>
          <span class="year-role">{{ record.subtitle }}</span>

          <ul class="year-items">
            {% for item in record.items -%}
              <li>{{ item }}</li>
            {%- endfor %}
          </ul>
        </div>
      </div>
    {%- endfor %}
  </div>
</section>
