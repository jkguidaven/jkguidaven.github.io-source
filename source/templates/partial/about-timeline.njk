<section class="timeline-section" id="experience">
  <div class="section-eyebrow">Career</div>
  <h2 class="section-title">Experience & Education</h2>

  <div class="timeline">
    {% for record in timeline -%}
      <div class="timeline-entry {{ 'education' if record.icon === 'graduation-cap' }}">
        <span class="entry-time">{{ record.time }}</span>
        <div class="entry-title">{{ record.title }}</div>
        <div class="entry-subtitle">{{ record.subtitle }}</div>

        <ul class="entry-items">
          {% for item in record.items -%}
            <li>{{ item }}</li>
          {%- endfor %}
        </ul>
      </div>
    {%- endfor %}
  </div>
</section>
